# Supabase (https://supabase.com/dashboard) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings → API — use only on the server (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (https://dashboard.stripe.com/)
# Used by subscription upgrade + webhook sync.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_ADVANCED_MONTHLY=

# Optional fallback when Origin header is unavailable (used for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=

# Optional: footer "Contact us" mailto (defaults in code if unset — set for production)
NEXT_PUBLIC_CONTACT_EMAIL=

# Admin login (used by /admin)
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Long random string in production (signs admin session cookie)
ADMIN_SESSION_SECRET=

# Resend (https://resend.com) — affiliate application confirmation email
# When either is unset, confirmation email is skipped (application still succeeds).
RESEND_API_KEY=
# Verified sender, e.g. FireDoor Network <onboarding@resend.dev> or your domain
RESEND_FROM_EMAIL=
